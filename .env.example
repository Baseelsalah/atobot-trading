# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
AI_INTEGRATIONS_OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
# Optional: Set to "1" to disable OpenAI and use deterministic strategies only
DISABLE_OPENAI=0

# Alpaca Trading API
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here

# Trading Configuration
# Optional: Comma-separated list of symbols to trade (defaults to baseline universe)
TRADING_UNIVERSE=SPY,QQQ,IWM
# Optional: Set to "1" to enable dry run mode (no real orders)
DRY_RUN=1

# Time Guard Override
# WARNING: Only set to "1" for testing. Disables FORT KNOX time-based safety checks
TIME_GUARD_OVERRIDE=0

# Simulation/Testing (Optional - for development only)
# Set to "1" to simulate market clock as open
SIM_CLOCK_OPEN=0
# Simulate specific Eastern Time for testing (format: YYYY-MM-DD HH:MM)
# SIM_TIME_ET=2026-02-04 10:00

# Debug Flags (Optional)
# Set to "1" to enable detailed strategy logging
DEBUG_STRATEGY=0
